# db — сервис postgres из docker-compose.yaml (запуск одним compose).
# Для docker-compose.hostnet.yaml используйте 127.0.0.1, для внешней БД — её адрес.
DATABASE_HOST=db
DATABASE_NAME=system_control_alerts
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_PORT=5432

SERVER_PORT=2255
WEB_PORT=3000
VITE_API_URL=/api

JWT_SECRET=change-me
JWT_EXPIRES_IN=2h
WS_HEARTBEAT_DEVICES_INTERVAL=30000

# Целевое реле и канал для системного звонка
RELAY_DEVICE_ID=a41942b7-4f77-4b13-90d5-da88294125f1
RING_CHANNEL_ID=6

# Сколько дней хранить записи журнала (старше — удаляются автоматически)
LOG_RETENTION_DAYS=30
